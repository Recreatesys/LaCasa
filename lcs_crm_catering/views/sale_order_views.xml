<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sale_order_view_form_inherit_lcs" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.lcs</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Add catering fields after partner_shipping_id -->
            <xpath expr="//field[@name='partner_shipping_id']" position="after">
                <field name="attention_to_id"
                       domain="[('parent_id', '=', partner_id)]"
                       context="{'default_parent_id': partner_id}"/>
                <field name="commitment_date" string="Event / Delivery Date"/>
                <field name="delivery_time" widget="float_time"/>
                <label for="event_hour"/>
                <div>
                    <field name="event_hour" class="oe_inline"/> Hours
                </div>
                <field name="call_van"/>
            </xpath>

            <!-- Add catering details group before order lines -->
            <xpath expr="//field[@name='order_line']" position="before">
                <group string="Catering Details">
                    <group>
                        <field name="brand"/>
                        <field name="client_type"/>
                        <field name="service_format"/>
                        <field name="service_type"/>
                        <field name="delivery_type"/>
                        <field name="setup_type"/>
                    </group>
                    <group>
                        <field name="guest_count"/>
                        <field name="payment_method"/>
                        <field name="event_remark"/>
                        <field name="no_logo"/>
                        <field name="is_wedding"
                               invisible="service_type != 'food_tasting'"/>
                        <field name="hide_prices_on_quote"/>
                        <field name="so_prefix_preview" readonly="1"/>
                    </group>
                </group>
            </xpath>

            <!-- Waiters tab — only relevant when service_format is Event Catering -->
            <xpath expr="//notebook" position="inside">
                <page string="Waiters" name="waiters"
                      invisible="service_format != 'event_catering'">
                    <group>
                        <group>
                            <field name="waiter_count" readonly="1"/>
                        </group>
                        <group>
                            <field name="waiter_total_hours" readonly="1"
                                   widget="float" digits="[8,2]"/>
                        </group>
                    </group>
                    <field name="waiter_line_ids">
                        <list editable="bottom"
                              decoration-info="order_state == 'draft'"
                              decoration-success="order_state in ('sale','done')">
                            <field name="employee_id"
                                   options="{'no_create': True}"/>
                            <field name="role" readonly="1"/>
                            <field name="start_datetime"/>
                            <field name="end_datetime"/>
                            <field name="hours" readonly="1" sum="Total"/>
                            <field name="order_state" column_invisible="1"/>
                        </list>
                    </field>
                    <p class="text-muted small mt-2">
                        Add staff who will be on the event. Quantity on the
                        auto-generated "Waiter Service" line equals the sum of
                        hours below. An employee cannot be double-booked across
                        confirmed Sales Orders.
                    </p>
                </page>

                <!-- Hardware tab — rented or sold goods listed on the SO -->
                <page string="Hardware" name="hardware">
                    <field name="hardware_line_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="product_id"
                                   options="{'no_create': True}"
                                   domain="[('type', '=', 'consu'), ('is_storable', '=', True)]"/>
                            <field name="goods_kind" optional="show"/>
                            <field name="product_uom_qty"/>
                            <field name="availability" readonly="1"/>
                            <field name="price_unit"/>
                            <field name="price_subtotal" sum="Total"/>
                            <field name="currency_id" column_invisible="1"/>
                        </list>
                    </field>
                    <group class="oe_subtotal_footer">
                        <field name="hardware_total" widget="monetary"/>
                    </group>
                    <p class="text-muted small mt-2">
                        Hardware items (storable goods) attached to this order.
                        Each row will be auto-mirrored as a Sales Order line under
                        a "Hardware" section. Mark a product as "For Rental" on its
                        product form to distinguish rentals from sales.
                    </p>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
