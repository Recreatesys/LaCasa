<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sale_order_view_form_inherit_lcs" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.lcs</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Add catering fields after partner_shipping_id -->
            <xpath expr="//field[@name='partner_shipping_id']" position="after">
                <field name="attention_to_id"
                       domain="[('parent_id', '=', partner_id)]"
                       context="{'default_parent_id': partner_id}"/>
                <label for="event_date_start" string="Event / Delivery Date"/>
                <div class="o_row">
                    <field name="event_date_start" nolabel="1" class="oe_inline"/>
                    <span class="mx-2">→</span>
                    <field name="event_date_end" nolabel="1" class="oe_inline"
                           placeholder="(single day)"/>
                    <field name="event_day_count" nolabel="1" class="oe_inline ms-2"
                           readonly="1" invisible="event_day_count &lt; 2"/>
                    <span invisible="event_day_count &lt; 2" class="ms-1">days</span>
                </div>
                <label for="event_time_start" string="Event / Delivery Time"/>
                <div class="o_row">
                    <field name="event_time_start" widget="float_time" nolabel="1" class="oe_inline"/>
                    <span class="mx-2">→</span>
                    <field name="event_time_end" widget="float_time" nolabel="1" class="oe_inline"/>
                </div>
                <label for="event_hour"/>
                <div>
                    <field name="event_hour" class="oe_inline"/> Hours
                </div>
                <field name="call_van"/>
            </xpath>

            <!-- Add catering details group ABOVE the notebook so it stays
                 visible in both single-day and multi-day layouts (in
                 multi-day the standard Order Lines tab is hidden). -->
            <xpath expr="//notebook" position="before">
                <group string="Catering Details">
                    <group>
                        <field name="brand"/>
                        <field name="client_type"/>
                        <field name="service_format"/>
                        <field name="service_type"/>
                        <field name="delivery_type"/>
                        <field name="waiter_service"/>
                    </group>
                    <group>
                        <field name="guest_count"/>
                        <field name="payment_method"/>
                        <field name="event_remark"/>
                        <field name="no_logo"/>
                        <field name="is_wedding"
                               invisible="service_type != 'food_tasting'"/>
                        <field name="hide_prices_on_quote"/>
                        <field name="so_prefix_preview" readonly="1"/>
                    </group>
                </group>
            </xpath>

            <!-- Time Slots management area (multi-slot events: breakfast +
                 lunch + tea, or multi-day, or both). Every SO has ≥1 slot.
                 Users add / edit slots inline; sequence handle re-orders.
                 Rendered above the notebook so it's visible everywhere. -->
            <xpath expr="//notebook" position="before">
                <field name="time_slot_count" invisible="1"/>
                <group string="Time Slots">
                    <field name="time_slot_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="label"/>
                            <field name="date"/>
                            <field name="time_start" widget="float_time"/>
                            <field name="time_end" widget="float_time"/>
                            <field name="guest_count"/>
                            <field name="slot_offset" column_invisible="1"/>
                        </list>
                    </field>
                </group>
            </xpath>

            <!-- Multi-slot: hide the stock Order Lines tab when >1 slot; the
                 per-slot tabs below take over. -->
            <xpath expr="//page[@name='order_lines']" position="attributes">
                <attribute name="invisible">time_slot_count &gt; 1</attribute>
            </xpath>

            <!-- Hide Delivered / Invoiced columns by default (users can
                 re-enable them via the column selector). -->
            <xpath expr="//field[@name='order_line']//list//field[@name='qty_delivered']"
                   position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//list//field[@name='qty_invoiced']"
                   position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>

            <!-- Hide the "Discount" wizard button (global-discount action). -->
            <xpath expr="//button[@name='action_open_discount_wizard']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Per-slot Order Lines tabs (up to 7). Each renders a filtered
                 slice of order_line via the same order_line_day_N computed
                 O2Ms — those filter by event_day_offset, which is
                 auto-synced from time_slot_id.slot_offset. Tab visibility
                 is now driven by time_slot_count. -->
            <xpath expr="//notebook" position="inside">
                <page string="Slot 1 Order Lines" name="order_lines_day_1"
                      invisible="time_slot_count &lt; 2">
                    <field name="order_line_day_1"
                           context="{'default_event_day_offset': 0}">
                        <list editable="bottom">
                            <field name="product_id"/>
                            <field name="name"/>
                            <field name="product_uom_qty"/>
                            <field name="price_unit"/>
                            <field name="price_subtotal" sum="Subtotal"/>
                            <field name="event_day_offset" column_invisible="1"/>
                        </list>
                    </field>
                </page>
                <page string="Slot 2 Order Lines" name="order_lines_day_2"
                      invisible="time_slot_count &lt; 2">
                    <field name="order_line_day_2"
                           context="{'default_event_day_offset': 1}">
                        <list editable="bottom">
                            <field name="product_id"/>
                            <field name="name"/>
                            <field name="product_uom_qty"/>
                            <field name="price_unit"/>
                            <field name="price_subtotal" sum="Subtotal"/>
                            <field name="event_day_offset" column_invisible="1"/>
                        </list>
                    </field>
                </page>
                <page string="Slot 3 Order Lines" name="order_lines_day_3"
                      invisible="time_slot_count &lt; 3">
                    <field name="order_line_day_3"
                           context="{'default_event_day_offset': 2}">
                        <list editable="bottom">
                            <field name="product_id"/>
                            <field name="name"/>
                            <field name="product_uom_qty"/>
                            <field name="price_unit"/>
                            <field name="price_subtotal" sum="Subtotal"/>
                            <field name="event_day_offset" column_invisible="1"/>
                        </list>
                    </field>
                </page>
                <page string="Slot 4 Order Lines" name="order_lines_day_4"
                      invisible="time_slot_count &lt; 4">
                    <field name="order_line_day_4"
                           context="{'default_event_day_offset': 3}">
                        <list editable="bottom">
                            <field name="product_id"/>
                            <field name="name"/>
                            <field name="product_uom_qty"/>
                            <field name="price_unit"/>
                            <field name="price_subtotal" sum="Subtotal"/>
                            <field name="event_day_offset" column_invisible="1"/>
                        </list>
                    </field>
                </page>
                <page string="Slot 5 Order Lines" name="order_lines_day_5"
                      invisible="time_slot_count &lt; 5">
                    <field name="order_line_day_5"
                           context="{'default_event_day_offset': 4}">
                        <list editable="bottom">
                            <field name="product_id"/>
                            <field name="name"/>
                            <field name="product_uom_qty"/>
                            <field name="price_unit"/>
                            <field name="price_subtotal" sum="Subtotal"/>
                            <field name="event_day_offset" column_invisible="1"/>
                        </list>
                    </field>
                </page>
                <page string="Slot 6 Order Lines" name="order_lines_day_6"
                      invisible="time_slot_count &lt; 6">
                    <field name="order_line_day_6"
                           context="{'default_event_day_offset': 5}">
                        <list editable="bottom">
                            <field name="product_id"/>
                            <field name="name"/>
                            <field name="product_uom_qty"/>
                            <field name="price_unit"/>
                            <field name="price_subtotal" sum="Subtotal"/>
                            <field name="event_day_offset" column_invisible="1"/>
                        </list>
                    </field>
                </page>
                <page string="Slot 7 Order Lines" name="order_lines_day_7"
                      invisible="time_slot_count &lt; 7">
                    <field name="order_line_day_7"
                           context="{'default_event_day_offset': 6}">
                        <list editable="bottom">
                            <field name="product_id"/>
                            <field name="name"/>
                            <field name="product_uom_qty"/>
                            <field name="price_unit"/>
                            <field name="price_subtotal" sum="Subtotal"/>
                            <field name="event_day_offset" column_invisible="1"/>
                        </list>
                    </field>
                </page>
            </xpath>

            <!-- Waiters tab — visible only when Waiter Service is ticked -->
            <xpath expr="//notebook" position="inside">
                <page string="Waiters" name="waiters"
                      invisible="not waiter_service">
                    <group>
                        <group>
                            <field name="waiter_count"
                                   readonly="has_waiter_rows"/>
                        </group>
                        <group>
                            <field name="waiter_total_hours"
                                   widget="float" digits="[8,2]"
                                   readonly="has_waiter_rows"/>
                        </group>
                    </group>
                    <p class="text-muted small" invisible="has_waiter_rows">
                        Waiter table is empty — # Waiters and Total Person-Hours can
                        be typed manually. They auto-sync to the table once you add
                        rows below.
                    </p>
                    <field name="waiter_line_ids">
                        <list editable="bottom"
                              decoration-info="order_state == 'draft'"
                              decoration-success="order_state in ('sale','done')">
                            <field name="employee_id"
                                   options="{'no_create': True}"/>
                            <field name="role" readonly="1"/>
                            <field name="start_datetime"/>
                            <field name="end_datetime"/>
                            <field name="hours" readonly="1" sum="Total"/>
                            <field name="order_state" column_invisible="1"/>
                        </list>
                    </field>
                    <p class="text-muted small mt-2">
                        Add staff who will be on the event. Quantity on the
                        auto-generated "Waiter Service" line equals the sum of
                        hours below. An employee cannot be double-booked across
                        confirmed Sales Orders.
                    </p>
                </page>

                <!-- Utensil & Equipment tab — rented or sold goods listed on the SO -->
                <page string="Utensil &amp; Equipment" name="hardware">
                    <field name="hardware_line_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="product_id"
                                   options="{'no_create': True}"
                                   domain="[('type', '=', 'consu'), ('is_storable', '=', True)]"/>
                            <field name="goods_kind" optional="show"/>
                            <field name="product_uom_qty"/>
                            <field name="availability" readonly="1"/>
                            <field name="price_unit"/>
                            <field name="price_subtotal" sum="Total"/>
                            <field name="currency_id" column_invisible="1"/>
                        </list>
                    </field>
                    <group class="oe_subtotal_footer">
                        <field name="hardware_total" widget="monetary"/>
                    </group>
                    <p class="text-muted small mt-2">
                        Hardware items (storable goods) attached to this order.
                        Each row will be auto-mirrored as a Sales Order line under
                        a "Hardware" section. Mark a product as "For Rental" on its
                        product form to distinguish rentals from sales.
                    </p>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
