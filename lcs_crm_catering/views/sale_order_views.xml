<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sale_order_view_form_inherit_lcs" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.lcs</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Add catering fields after partner_shipping_id -->
            <xpath expr="//field[@name='partner_shipping_id']" position="after">
                <field name="attention_to_id"
                       domain="[('parent_id', '=', partner_id)]"
                       context="{'default_parent_id': partner_id}"/>
                <field name="event_date"/>
                <label for="event_time_start" string="Event / Delivery Time"/>
                <div class="o_row">
                    <field name="event_time_start" widget="float_time" nolabel="1" class="oe_inline"/>
                    <span class="mx-2">→</span>
                    <field name="event_time_end" widget="float_time" nolabel="1" class="oe_inline"/>
                </div>
                <label for="event_hour"/>
                <div>
                    <field name="event_hour" class="oe_inline"/> Hours
                </div>
                <field name="call_van"/>
            </xpath>

            <!-- Add catering details group ABOVE the notebook so it stays
                 visible in both single-day and multi-day layouts (in
                 multi-day the standard Order Lines tab is hidden). -->
            <xpath expr="//notebook" position="before">
                <group string="Catering Details">
                    <group>
                        <field name="brand"/>
                        <field name="client_type"/>
                        <field name="service_format"/>
                        <field name="service_type"/>
                        <field name="delivery_type"/>
                        <field name="waiter_service"/>
                    </group>
                    <group>
                        <field name="guest_count"/>
                        <field name="payment_method"/>
                        <field name="event_remark"/>
                        <field name="no_logo"/>
                        <field name="is_wedding"
                               invisible="service_type != 'food_tasting'"/>
                        <field name="hide_prices_on_quote"/>
                        <field name="so_prefix_preview" readonly="1"/>
                    </group>
                </group>
            </xpath>

            <!-- Hide Delivered / Invoiced columns by default (users can
                 re-enable them via the column selector). -->
            <xpath expr="//field[@name='order_line']//list//field[@name='qty_delivered']"
                   position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//list//field[@name='qty_invoiced']"
                   position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>

            <!-- Hide the "Discount" wizard button (global-discount action). -->
            <xpath expr="//button[@name='action_open_discount_wizard']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Waiters tab — visible only when Waiter Service is ticked -->
            <xpath expr="//notebook" position="inside">
                <page string="Waiters" name="waiters"
                      invisible="not waiter_service">
                    <group>
                        <group>
                            <field name="waiter_count"
                                   readonly="has_waiter_rows"/>
                        </group>
                        <group>
                            <field name="waiter_total_hours"
                                   widget="float" digits="[8,2]"
                                   readonly="has_waiter_rows"/>
                        </group>
                    </group>
                    <p class="text-muted small" invisible="has_waiter_rows">
                        Waiter table is empty — # Waiters and Total Person-Hours can
                        be typed manually. They auto-sync to the table once you add
                        rows below.
                    </p>
                    <field name="waiter_line_ids">
                        <list editable="bottom"
                              decoration-info="order_state == 'draft'"
                              decoration-success="order_state in ('sale','done')">
                            <field name="employee_id"
                                   options="{'no_create': True}"/>
                            <field name="role" readonly="1"/>
                            <field name="start_datetime"/>
                            <field name="end_datetime"/>
                            <field name="hours" readonly="1" sum="Total"/>
                            <field name="order_state" column_invisible="1"/>
                        </list>
                    </field>
                    <p class="text-muted small mt-2">
                        Add staff who will be on the event. Quantity on the
                        auto-generated "Waiter Service" line equals the sum of
                        hours below. An employee cannot be double-booked across
                        confirmed Sales Orders.
                    </p>
                </page>

                <!-- Utensil & Equipment tab — rented or sold goods listed on the SO -->
                <page string="Utensil &amp; Equipment" name="hardware">
                    <field name="hardware_line_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="product_id"
                                   options="{'no_create': True}"
                                   domain="[('type', '=', 'consu'), ('is_storable', '=', True)]"/>
                            <field name="goods_kind" optional="show"/>
                            <field name="product_uom_qty"/>
                            <field name="availability" readonly="1"/>
                            <field name="price_unit"/>
                            <field name="price_subtotal" sum="Total"/>
                            <field name="currency_id" column_invisible="1"/>
                        </list>
                    </field>
                    <group class="oe_subtotal_footer">
                        <field name="hardware_total" widget="monetary"/>
                    </group>
                    <p class="text-muted small mt-2">
                        Hardware items (storable goods) attached to this order.
                        Each row will be auto-mirrored as a Sales Order line under
                        a "Hardware" section. Mark a product as "For Rental" on its
                        product form to distinguish rentals from sales.
                    </p>
                </page>
            </xpath>
        </field>
    </record>


    <!-- Sales Order LIST view: expose Event Date, Event Time, Event Hour
         columns by default. Inherits from the root sale_order_tree so the
         change applies to both the Quotations list and the Sales Orders
         list (both are primary inheritances of this root). -->
    <record id="sale_order_tree_inherit_lcs" model="ir.ui.view">
        <field name="name">sale.order.tree.inherit.lcs</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_order']" position="after">
                <field name="event_date" string="Event / Delivery Date" optional="show"/>
                <field name="event_time_start" widget="float_time"
                       string="Event / Delivery Time" optional="show"/>
                <field name="event_hour" string="Event Hour" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
