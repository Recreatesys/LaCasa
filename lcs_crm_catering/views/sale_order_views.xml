<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sale_order_view_form_inherit_lcs" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.lcs</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Add catering fields after partner_shipping_id -->
            <xpath expr="//field[@name='partner_shipping_id']" position="after">
                <field name="attention_to_id"
                       domain="[('parent_id', '=', partner_id)]"
                       context="{'default_parent_id': partner_id}"/>
                <field name="delivery_time" widget="float_time"/>
                <label for="event_hour"/>
                <div>
                    <field name="event_hour" class="oe_inline"/> Hours
                </div>
                <field name="call_van"/>
            </xpath>

            <!-- Add catering details group before order lines -->
            <xpath expr="//field[@name='order_line']" position="before">
                <group string="Catering Details">
                    <group>
                        <field name="brand"/>
                        <field name="client_type"/>
                        <field name="service_format"/>
                        <field name="service_type"/>
                        <field name="delivery_type"/>
                        <field name="setup_type"/>
                    </group>
                    <group>
                        <field name="guest_count"/>
                        <field name="payment_method"/>
                        <field name="event_remark"/>
                        <field name="no_logo"/>
                        <field name="is_wedding"
                               invisible="service_type != 'food_tasting'"/>
                        <field name="hide_prices_on_quote"/>
                        <field name="so_prefix_preview" readonly="1"/>
                    </group>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
