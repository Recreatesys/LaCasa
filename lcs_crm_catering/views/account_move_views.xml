<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_move_form_inherit_lcs" model="ir.ui.view">
        <field name="name">account.move.form.inherit.lcs</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Add attention_to, delivery time, call van in the header left group -->
            <xpath expr="//group[@id='header_left_group']" position="inside">
                <field name="attention_to_id"
                       domain="[('parent_id', '=', partner_id)]"/>
                <field name="delivery_time" widget="float_time"/>
                <label for="event_hour"/>
                <div>
                    <field name="event_hour" class="oe_inline"/> Hours
                </div>
                <field name="call_van"/>
            </xpath>

            <!-- Add catering details before invoice lines -->
            <xpath expr="//field[@name='invoice_line_ids']" position="before">
                <group string="Catering Details">
                    <group>
                        <field name="brand"/>
                        <field name="service_format"/>
                        <field name="service_type"/>
                        <field name="delivery_type"/>
                        <field name="waiter_service"/>
                    </group>
                    <group>
                        <field name="guest_count"/>
                        <field name="payment_method"/>
                        <field name="event_remark"/>
                        <field name="no_logo"/>
                        <field name="is_wedding"
                               invisible="service_type != 'food_tasting'"/>
                    </group>
                </group>
            </xpath>

            <!-- Sets & Services Summary table injected ABOVE the editable
                 invoice_line_ids list on the standard Invoice Lines tab.
                 Read-only; auto-refreshes as the user edits lines. -->
            <xpath expr="//field[@name='invoice_line_ids']" position="before">
                <field name="lcs_invoice_summary_html"
                       nolabel="1" readonly="1"/>
            </xpath>

            <!-- "Grouped Preview" tab — mirrors the PDF's two-table layout
                 (Sets & Services Summary + per-set Food Choices). Read-only
                 view of the invoice's catering structure. Add / edit lines
                 in the standard Invoice Lines tab; this tab auto-refreshes. -->
            <xpath expr="//page[@id='invoice_tab']" position="after">
                <page string="Grouped Preview" name="lcs_grouped_preview">
                    <field name="lcs_invoice_grouped_html"
                           nolabel="1" readonly="1"/>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
