<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="mail_compose_message_view_form_lcs" model="ir.ui.view">
        <field name="name">mail.compose.message.form.inherit.lcs</field>
        <field name="model">mail.compose.message</field>
        <field name="inherit_id" ref="mail.email_compose_message_wizard_form"/>
        <field name="arch" type="xml">

            <!-- CC field, just above the Subject line. The parent <group>
                 auto-renders the label from the field's `string="Cc"`. -->
            <xpath expr="//field[@name='subject']" position="before">
                <field name="email_cc"
                       placeholder="e.g. copies@company.com, boss@company.com"
                       invisible="composition_mode != 'comment' or subtype_is_log"/>
            </xpath>

        </field>
    </record>

</odoo>
