<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="crm_lead_view_form_inherit_lcs" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.lcs</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <!-- Hide the Properties widget on the CRM lead form.
                 Odoo auto-injects "Property 1", "Property 2", etc. from the
                 pipeline's property definitions; LCS does not use them. -->
            <xpath expr="//field[@name='lead_properties']" position="attributes">
                <attribute name="invisible">1</attribute>
                <attribute name="readonly">1</attribute>
            </xpath>

            <!-- Create/View Quotations buttons in the statusbar at the very
                 top of the form — small, aligned side by side. -->
            <xpath expr="//header" position="inside">
                <button name="action_create_quotations_from_slots"
                        string="Create Quotations"
                        type="object"
                        class="btn-primary btn-sm"
                        icon="fa-file-text-o"
                        confirm="Create one draft quotation per unquoted slot?"/>
                <button name="action_view_opportunity_quotations"
                        string="View Quotations"
                        type="object"
                        class="btn-secondary btn-sm"
                        icon="fa-external-link"/>
            </xpath>

            <!-- Add catering fields before the notebook (after partner/salesperson groups) -->
            <xpath expr="//notebook" position="before">
                <group string="Catering Details">
                    <group>
                        <field name="brand"/>
                        <field name="client_type"/>
                        <field name="service_format"/>
                        <field name="service_type"/>
                        <field name="delivery_type"/>
                        <field name="waiter_service"/>
                        <field name="call_van"/>
                    </group>
                    <group>
                        <label for="event_date_start" string="Event / Delivery Date"/>
                        <div class="o_row">
                            <field name="event_date_start" nolabel="1" class="oe_inline"/>
                            <span class="mx-2">→</span>
                            <field name="event_date_end" nolabel="1" class="oe_inline"
                                   placeholder="(single day)"/>
                            <field name="event_day_count" nolabel="1" class="oe_inline ms-2"
                                   readonly="1" invisible="event_day_count &lt; 2"/>
                            <span invisible="event_day_count &lt; 2" class="ms-1">days</span>
                        </div>
                        <label for="event_time_start" string="Event / Delivery Time"/>
                        <div class="o_row">
                            <field name="event_time_start" widget="float_time" nolabel="1" class="oe_inline"/>
                            <span class="mx-2">→</span>
                            <field name="event_time_end" widget="float_time" nolabel="1" class="oe_inline"/>
                        </div>
                        <label for="event_hour"/>
                        <div>
                            <field name="event_hour" class="oe_inline"/> Hours
                        </div>
                        <field name="guest_count"/>
                        <field name="no_logo"/>
                        <field name="is_wedding"
                               invisible="service_type != 'food_tasting'"/>
                    </group>
                </group>
                <group string="Event / Delivery Address">
                    <group>
                        <field name="event_street" string="Street"/>
                        <field name="event_street2" string="Street 2"/>
                        <field name="event_country_id" string="Country"/>
                    </group>
                    <group>
                        <field name="event_remark"/>
                    </group>
                </group>

                <!-- Time Slots — each row becomes a quotation on "Create
                     Quotations". After the first click, saving a new slot
                     auto-creates that slot's quotation. -->
                <group string="Time Slots">
                    <field name="quotations_created" invisible="1"/>
                    <field name="time_slot_count" invisible="1"/>
                    <field name="time_slot_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="label"/>
                            <field name="date"/>
                            <field name="time_start" widget="float_time"/>
                            <field name="time_end" widget="float_time"/>
                            <field name="guest_count"/>
                            <field name="order_id" readonly="1"
                                   string="Quotation" optional="show"/>
                        </list>
                    </field>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
