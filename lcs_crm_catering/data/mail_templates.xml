<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- SO "Send by Email" attaches LCS Quotation (not the stock report). -->
        <record id="sale.email_template_edi_sale" model="mail.template">
            <field name="report_template_ids"
                   eval="[Command.set([ref('lcs_crm_catering.action_report_quotation_lcs')])]"/>
        </record>

        <!-- Invoice "Send by Email" attaches LCS Invoice. -->
        <record id="account.email_template_edi_invoice" model="mail.template">
            <field name="report_template_ids"
                   eval="[Command.set([ref('lcs_crm_catering.action_report_invoice_lcs')])]"/>
        </record>

    </data>
</odoo>
