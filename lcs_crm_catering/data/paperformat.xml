<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- LCS A4 paperformat — tight margins, no reserved header spacing.
         Default Odoo paperformat reserves ~40mm at top for header which
         pushes our custom-headered reports down. -->
    <record id="paperformat_lcs_a4" model="report.paperformat">
        <field name="name">LCS A4</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">15</field>
        <field name="margin_left">12</field>
        <field name="margin_right">12</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

</odoo>
