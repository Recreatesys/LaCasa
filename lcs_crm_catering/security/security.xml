<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="group_kitchen_user" model="res.groups">
            <field name="name">Kitchen</field>
            <field name="category_id" ref="base.module_category_operations"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Kitchen staff: read-only access to CRM opportunities at "High Chance" and "Won" stages only.</field>
        </record>

        <record id="crm_lead_kitchen_rule" model="ir.rule">
            <field name="name">Kitchen: High Chance &amp; Won opportunities only</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="groups" eval="[(4, ref('group_kitchen_user'))]"/>
            <field name="domain_force">[('type', '=', 'opportunity'), ('stage_id.name', 'in', ['High Chance', 'Won'])]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>
