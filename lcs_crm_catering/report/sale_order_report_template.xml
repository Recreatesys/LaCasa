<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- LCS Quotation Report                                         -->
    <!-- Page 1: Summary + payment / reschedule terms                 -->
    <!-- Page 2+: Delivery details + line items                       -->
    <!-- ============================================================ -->
    <template id="report_quotation_lcs" inherit_id="sale.report_saleorder" primary="True">
        <xpath expr="." position="replace">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-set="lang" t-value="o.partner_id.lang"/>
                    <t t-call="lcs_crm_catering.report_quotation_lcs_document" t-lang="lang"/>
                </t>
            </t>
        </xpath>
    </template>

    <template id="report_quotation_lcs_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="lcs_crm_catering.report_quotation_lcs_page" t-lang="o.partner_id.lang"/>
            </t>
        </t>
    </template>

    <template id="report_quotation_lcs_page">
        <t t-call="web.basic_layout">
            <t t-set="o" t-value="o"/>
            <t t-set="hide_prices" t-value="o.hide_prices_on_quote"/>
            <t t-set="show_logo" t-value="not o.no_logo and o.company_id.logo"/>

            <!-- ============================================================ -->
            <!-- PAGE 1: Summary + Terms                                      -->
            <!-- ============================================================ -->
            <div class="page" style="font-family: Arial, sans-serif; font-size: 12px;">

                <!-- Company Header -->
                <div style="margin-bottom: 20px;">
                    <div style="margin-bottom: 10px;">
                        <img t-if="show_logo" t-att-src="image_data_uri(o.company_id.logo)"
                             style="max-height: 60px;" alt="Logo"/>
                    </div>
                    <div>
                        <span t-field="o.company_id.partner_id.name"/><br/>
                        <t t-if="o.company_id.partner_id.street">
                            <span t-field="o.company_id.partner_id.street"/>
                            <t t-if="o.company_id.partner_id.street2">, <span t-field="o.company_id.partner_id.street2"/></t><br/>
                        </t>
                        <t t-if="o.company_id.phone">Tel: <span t-field="o.company_id.phone"/></t>
                        <t t-if="o.company_id.phone and o.company_id.email"> | </t>
                        <t t-if="o.company_id.email">Email: <span t-field="o.company_id.email"/></t>
                    </div>
                </div>

                <!-- Title -->
                <h1 style="font-size: 24px; font-weight: bold; margin-bottom: 15px;">
                    <t t-if="o.state in ('draft', 'sent')">Quotation</t>
                    <t t-else="">Sales Order</t>
                </h1>

                <!-- Reference and Dates -->
                <table style="width: 100%; margin-bottom: 15px;">
                    <tr>
                        <td style="width: 50%; vertical-align: top;">
                            <strong>Quote No.:</strong> <span t-field="o.name"/>
                        </td>
                        <td style="text-align: right; vertical-align: top;">
                            <strong>Quote Date:</strong>
                            <span t-field="o.date_order" t-options='{"format": "d/MMM/yyyy"}'/><br/>
                            <t t-if="o.validity_date">
                                <strong>Valid Until:</strong>
                                <span t-field="o.validity_date" t-options='{"format": "d/MMM/yyyy"}'/>
                            </t>
                        </td>
                    </tr>
                </table>

                <!-- Customer Info -->
                <div style="margin-bottom: 15px;">
                    <span t-field="o.partner_id.name" style="font-size: 14px; font-weight: bold;"/><br/>
                    <t t-if="o.partner_id.street"><span t-field="o.partner_id.street"/><br/></t>
                    <t t-if="o.partner_id.street2"><span t-field="o.partner_id.street2"/><br/></t>
                    <t t-if="o.attention_to_id">
                        Attn: <span t-field="o.attention_to_id.name"/><br/>
                    </t>
                    <t t-if="o.commitment_date or o.delivery_type">
                        Catering service
                        <t t-if="o.commitment_date">on
                            <span t-field="o.commitment_date" t-options='{"format": "EEEE, d MMMM yyyy"}'/>
                        </t>
                    </t>
                </div>

                <!-- Service Summary Table -->
                <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                    <thead>
                        <tr style="border-bottom: 1px solid #000;">
                            <th style="text-align: left; padding: 5px;">Service Description</th>
                            <th t-if="not hide_prices" style="text-align: right; padding: 5px; width: 120px;">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td style="padding: 10px 5px; vertical-align: top;">
                                <t t-if="o.delivery_type">
                                    <span t-field="o.delivery_type"/><br/>
                                </t>
                                <t t-if="o.service_type">
                                    Service Type: <span t-field="o.service_type"/><br/>
                                </t>
                                <t t-if="o.guest_count">
                                    Guest Count: <span t-field="o.guest_count"/><br/>
                                </t>
                                <span style="color: #666;">Details please refer to Appendix</span>
                            </td>
                            <td t-if="not hide_prices" style="text-align: right; padding: 10px 5px; vertical-align: top;">
                                HK$<span t-field="o.amount_total" t-options='{"widget": "monetary", "display_currency": False}'/>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <!-- Terms &amp; Conditions -->
                <div style="margin-bottom: 20px; font-size: 11px;">
                    <strong>Terms &amp; Conditions</strong><br/>
                    1. The quotation normally valid for 7 days from the date of issue.<br/>
                    2. 50% deposit has to be made within 7 days after signing the quotation and the remaining deposit has to be made 7 days before the event;<br/>
                    3. Payment can be made by cheque with the payee name of La Casa Management Company Ltd or by bank transfer through Bank of East Asia with payee name of La Casa Management Company Ltd (a/c no: 015-187-68-00209-0)<br/>
                    4. La Casa shall not be responsible for any delivery delays or misadventures due to the unforeseeable traffic incidents, unclear delivery instructions, inaccurate address or any missing or incorrect information. La Casa reserves the right to apply surcharge for any extra effort in delivery.<br/>
                    <br/>
                    <strong>Reschedule / Cancellation:</strong><br/>
                    1. More than or equal to 7-day notice*, the catering service can be rescheduled to later dates within 3 months <u>without extra charge</u>;<br/>
                    2. less than 7-day notice*: 30% of the total invoice amount;<br/>
                    3. less than 4-day notice*: 50% of the total invoice amount;<br/>
                    4. less than 2-day notice*: 100% of the total invoice amount.<br/>
                    <br/>
                    - Food Delivery / catering service will not be provided if Typhoon Signal No. 8 or above or Black Rainstorm Signal is hoisted or under 'extreme condition'. The delivery can be resumed within four hours after Typhoon Signal No. 8 or above or black rainstorm warning is lowered, depends on the traffic condition. The delivery can also be rescheduled on next day <u>without extra charge</u> OR later dates within 3 months with extra charge of 50% of the total invoice amount.<br/>
                    <br/>
                    *Day of notice here refers to working days, that means Mon-Fri, except Sat, Sun &amp; Public Holidays.<br/>
                    <br/>
                    - La Casa shall not be responsible for any delivery delays or misadventures due to the unforeseeable traffic incidents, unclear delivery instructions, inaccurate address or any missing or incorrect information. La Casa reserves the right to apply surcharge for any extra effort in delivery.
                </div>

                <!-- Total -->
                <table t-if="not hide_prices" style="width: 100%; margin-bottom: 20px;">
                    <tr>
                        <td style="text-align: right; padding: 5px; border-top: 1px solid #000;">
                            <strong>Total:</strong>
                        </td>
                        <td style="text-align: right; padding: 5px; border-top: 1px solid #000; width: 120px;">
                            <strong>HK$<span t-field="o.amount_total" t-options='{"widget": "monetary", "display_currency": False}'/></strong>
                        </td>
                    </tr>
                </table>

                <div t-if="hide_prices" style="margin-bottom: 20px; padding: 8px; border: 1px dashed #999; font-size: 11px; color: #666;">
                    <em>Pricing not shown on this quotation — please contact us for the final quote.</em>
                </div>

                <!-- Thank you -->
                <div style="text-align: center; margin-top: 30px;">
                    <strong>Thank You for Your Business!</strong>
                </div>

            </div>

            <!-- ============================================================ -->
            <!-- PAGE 2+: Appendix (Detail Lines)                             -->
            <!-- ============================================================ -->
            <div class="page" style="font-family: Arial, sans-serif; font-size: 12px; page-break-before: always;">

                <!-- Company Header (repeated) -->
                <div style="margin-bottom: 20px;">
                    <img t-if="show_logo" t-att-src="image_data_uri(o.company_id.logo)"
                         style="max-height: 60px;" alt="Logo"/>
                </div>

                <!-- Delivery Details -->
                <table style="width: 100%; margin-bottom: 20px;">
                    <tr>
                        <td style="width: 150px;"><strong>Quote No.:</strong></td>
                        <td><span t-field="o.name"/></td>
                    </tr>
                    <tr t-if="o.commitment_date">
                        <td><strong>Delivery Date:</strong></td>
                        <td>
                            <span t-field="o.commitment_date" t-options='{"format": "EEEE, d MMMM yyyy"}'/>
                        </td>
                    </tr>
                    <tr t-if="o.delivery_time">
                        <td><strong>Delivery Time:</strong></td>
                        <td><span t-field="o.delivery_time" widget="float_time"/></td>
                    </tr>
                    <tr t-if="o.partner_shipping_id and o.partner_shipping_id.street">
                        <td><strong>Delivery Address:</strong></td>
                        <td>
                            <span t-field="o.partner_shipping_id.street"/>
                            <t t-if="o.partner_shipping_id.street2">, <span t-field="o.partner_shipping_id.street2"/></t>
                        </td>
                    </tr>
                    <tr t-if="o.attention_to_id">
                        <td><strong>Contact Person:</strong></td>
                        <td><span t-field="o.attention_to_id.name"/></td>
                    </tr>
                    <tr t-if="o.attention_to_id and o.attention_to_id.phone">
                        <td><strong>Contact Number:</strong></td>
                        <td><span t-field="o.attention_to_id.phone"/></td>
                    </tr>
                    <tr t-if="o.event_remark">
                        <td style="vertical-align: top;"><strong>Remark:</strong></td>
                        <td><span t-field="o.event_remark"/></td>
                    </tr>
                </table>

                <!-- Detail Product Lines -->
                <table style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr style="border-bottom: 1px solid #000;">
                            <th style="text-align: left; padding: 5px;">Dish Name</th>
                            <th t-if="not hide_prices" style="text-align: right; padding: 5px; width: 80px;">Unit Price</th>
                            <th style="text-align: right; padding: 5px; width: 60px;">Qty</th>
                            <th t-if="not hide_prices" style="text-align: right; padding: 5px; width: 80px;">Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-set="visible_lines" t-value="o.order_line.filtered(lambda l: not l.display_type and (not l.is_set_line or l.dish_selected) and not l.is_addon_piece)"/>
                        <t t-foreach="visible_lines" t-as="line">
                            <tr style="border-bottom: 1px solid #eee;">
                                <td style="padding: 5px;">
                                    <span t-field="line.name"/>
                                </td>
                                <td t-if="not hide_prices" style="text-align: right; padding: 5px;">
                                    HK$<span t-field="line.price_unit"/>
                                </td>
                                <td style="text-align: right; padding: 5px;">
                                    <span t-field="line.product_uom_qty"/>
                                    <t t-if="line.set_unit">
                                        <small style="color: #666;"> <span t-field="line.set_unit"/></small>
                                    </t>
                                </td>
                                <td t-if="not hide_prices" style="text-align: right; padding: 5px;">
                                    HK$<span t-field="line.price_subtotal"/>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                    <tfoot t-if="not hide_prices">
                        <tr style="border-top: 1px solid #000;">
                            <td colspan="3" style="text-align: right; padding: 5px;"><strong>Total</strong></td>
                            <td style="text-align: right; padding: 5px;">
                                <strong>HK$<span t-field="o.amount_total" t-options='{"widget": "monetary", "display_currency": False}'/></strong>
                            </td>
                        </tr>
                    </tfoot>
                </table>

            </div>
        </t>
    </template>

    <!-- Register the report action -->
    <record id="action_report_quotation_lcs" model="ir.actions.report">
        <field name="name">LCS Quotation</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">lcs_crm_catering.report_quotation_lcs_document</field>
        <field name="report_file">lcs_crm_catering.report_quotation_lcs_document</field>
        <field name="paperformat_id" ref="paperformat_lcs_a4"/>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
