<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== LIST VIEW (Kitchen Dish Overview) ==================== -->
    <record id="lcs_event_order_line_view_list" model="ir.ui.view">
        <field name="name">lcs.event.order.line.list</field>
        <field name="model">lcs.event.order.line</field>
        <field name="arch" type="xml">
            <list string="Dish Overview" default_order="event_date asc, product_id asc"
                  create="0" delete="0" edit="0">
                <field name="event_date"/>
                <field name="order_id"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="description" optional="hide"/>
                <field name="kitchen_qty" sum="Total Qty"/>
                <field name="kitchen_uom"/>
                <field name="guest_count" sum="Total Guests"/>
                <field name="brand" optional="show"/>
                <field name="service_format" optional="hide"/>
                <field name="service_type" optional="hide"/>
                <field name="delivery_type" optional="hide"/>
                <field name="so_qty" optional="hide" sum="SO Qty"/>
                <field name="note" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ==================== PIVOT VIEW ==================== -->
    <record id="lcs_event_order_line_view_pivot" model="ir.ui.view">
        <field name="name">lcs.event.order.line.pivot</field>
        <field name="model">lcs.event.order.line</field>
        <field name="arch" type="xml">
            <pivot string="Dish Overview">
                <field name="product_id" type="row"/>
                <field name="event_date" type="col" interval="day"/>
                <field name="kitchen_qty" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ==================== GRAPH VIEW ==================== -->
    <record id="lcs_event_order_line_view_graph" model="ir.ui.view">
        <field name="name">lcs.event.order.line.graph</field>
        <field name="model">lcs.event.order.line</field>
        <field name="arch" type="xml">
            <graph string="Dish Overview" type="bar">
                <field name="product_id"/>
                <field name="kitchen_qty" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ==================== SEARCH VIEW ==================== -->
    <record id="lcs_event_order_line_view_search" model="ir.ui.view">
        <field name="name">lcs.event.order.line.search</field>
        <field name="model">lcs.event.order.line</field>
        <field name="arch" type="xml">
            <search string="Dish Overview">
                <field name="product_id"/>
                <field name="order_id"/>
                <field name="partner_id"/>
                <field name="event_date"/>
                <separator/>
                <filter name="filter_today" string="Today"
                        domain="[('event_date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="filter_this_week" string="This Week"
                        domain="[('event_date', '&gt;=', (context_today() + relativedelta(weeks=-context_today().weekday()/7, days=-context_today().weekday())).strftime('%Y-%m-%d')),
                                 ('event_date', '&lt;', (context_today() + relativedelta(weeks=-context_today().weekday()/7, days=7-context_today().weekday())).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_upcoming" string="Upcoming"
                        domain="[('event_date', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter name="filter_paid" string="Paid"
                        domain="[('payment_status', '=', 'paid')]"/>
                <filter name="filter_unpaid" string="Unpaid"
                        domain="[('payment_status', '=', 'unpaid')]"/>
                <filter name="filter_not_cancelled" string="Active (not cancelled)"
                        domain="[('payment_status', '!=', 'cancelled')]"/>
                <separator/>
                <group string="Group By">
                    <filter name="groupby_product" string="Dish"
                            context="{'group_by': 'product_id'}"/>
                    <filter name="groupby_event_date" string="Event Date"
                            context="{'group_by': 'event_date'}"/>
                    <filter name="groupby_partner" string="Customer"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="groupby_brand" string="Brand"
                            context="{'group_by': 'brand'}"/>
                    <filter name="groupby_service_format" string="Service Format"
                            context="{'group_by': 'service_format'}"/>
                    <filter name="groupby_service_type" string="Service Type"
                            context="{'group_by': 'service_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ==================== ACTION ==================== -->
    <record id="lcs_event_order_line_action" model="ir.actions.act_window">
        <field name="name">Dish Overview</field>
        <field name="res_model">lcs.event.order.line</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="search_view_id" ref="lcs_event_order_line_view_search"/>
        <field name="context">{
            'search_default_filter_upcoming': 1,
            'search_default_filter_not_cancelled': 1,
            'search_default_groupby_product': 1,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aggregated dish view across all Event Orders
            </p>
            <p>
                Shows each dish line with its event date, customer, guest count, and quantity. Group by Dish to see per-dish subtotals.
            </p>
        </field>
    </record>

</odoo>
