<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="lcs_menu_template_view_form" model="ir.ui.view">
        <field name="name">lcs.menu.template.form</field>
        <field name="model">lcs.menu.template</field>
        <field name="arch" type="xml">
            <form string="Weekly Menu Template">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Standard Week — Spring 2026"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="school_id"/>
                            <field name="class_company_id"
                                   help="Leave empty for school-wide. Class-specific overrides school-wide."/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="line_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Items by Weekday" name="items">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="weekday"/>
                                    <field name="sequence" widget="handle"/>
                                    <field name="item_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Note" name="note">
                            <field name="note" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="lcs_menu_template_view_list" model="ir.ui.view">
        <field name="name">lcs.menu.template.list</field>
        <field name="model">lcs.menu.template</field>
        <field name="arch" type="xml">
            <list string="Menu Templates">
                <field name="name"/>
                <field name="school_id"/>
                <field name="class_company_id"/>
                <field name="line_count" string="# Items"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="lcs_menu_template_action" model="ir.actions.act_window">
        <field name="name">Menu Templates</field>
        <field name="res_model">lcs.menu.template</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
