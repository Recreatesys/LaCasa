<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== SCHOOL: form ==================== -->
    <record id="lcs_school_view_form" model="ir.ui.view">
        <field name="name">lcs.school.form</field>
        <field name="model">lcs.school</field>
        <field name="arch" type="xml">
            <form string="School">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="School Name"/></h1>
                    </div>
                    <group>
                        <field name="short_code"/>
                        <field name="active"/>
                        <field name="student_count"/>
                    </group>
                    <notebook>
                        <page string="Classes" name="classes">
                            <field name="company_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="currency_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== SCHOOL: list ==================== -->
    <record id="lcs_school_view_list" model="ir.ui.view">
        <field name="name">lcs.school.list</field>
        <field name="model">lcs.school</field>
        <field name="arch" type="xml">
            <list string="Schools">
                <field name="name"/>
                <field name="short_code"/>
                <field name="student_count"/>
            </list>
        </field>
    </record>

    <!-- ==================== ALLERGY: list ==================== -->
    <record id="lcs_allergy_view_list" model="ir.ui.view">
        <field name="name">lcs.allergy.list</field>
        <field name="model">lcs.allergy</field>
        <field name="arch" type="xml">
            <list string="Allergies" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ==================== ACTIONS ==================== -->
    <record id="lcs_school_action" model="ir.actions.act_window">
        <field name="name">Schools</field>
        <field name="res_model">lcs.school</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="lcs_allergy_action" model="ir.actions.act_window">
        <field name="name">Allergies</field>
        <field name="res_model">lcs.allergy</field>
        <field name="view_mode">list</field>
    </record>

    <!-- ==================== STUDENTS action (filtered partners) ==================== -->
    <record id="lcs_student_action" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="domain">[('is_student', '=', True)]</field>
        <field name="context">{'default_is_student': True}</field>
    </record>

</odoo>
