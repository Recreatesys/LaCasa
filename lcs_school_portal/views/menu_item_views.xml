<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="lcs_menu_item_view_list" model="ir.ui.view">
        <field name="name">lcs.menu.item.list</field>
        <field name="model">lcs.menu.item</field>
        <field name="arch" type="xml">
            <list string="Menu Items">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="chinese_name" optional="show"/>
                <field name="price" sum="Total"/>
                <field name="diet_preference" optional="show"/>
                <field name="allergy_ids" widget="many2many_tags"
                       options="{'color_field': 'color'}" optional="show"/>
                <field name="school_id" optional="hide"/>
                <field name="active" optional="hide" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="lcs_menu_item_view_kanban" model="ir.ui.view">
        <field name="name">lcs.menu.item.kanban</field>
        <field name="model">lcs.menu.item</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="image"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex">
                            <img t-if="record.image.raw_value"
                                 t-att-src="kanban_image('lcs.menu.item','image',record.id.raw_value)"
                                 class="me-2" style="width:64px;height:64px;object-fit:cover;border-radius:6px;"
                                 alt="img"/>
                            <div class="flex-grow-1">
                                <strong><field name="name"/></strong>
                                <div class="text-muted small">
                                    <field name="chinese_name"/>
                                </div>
                                <div class="mt-1">
                                    <span class="badge text-bg-primary">$<field name="price"/></span>
                                    <field name="diet_preference" widget="badge"/>
                                </div>
                                <div class="mt-1">
                                    <field name="allergy_ids" widget="many2many_tags"
                                           options="{'color_field': 'color'}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="lcs_menu_item_view_form" model="ir.ui.view">
        <field name="name">lcs.menu.item.form</field>
        <field name="model">lcs.menu.item</field>
        <field name="arch" type="xml">
            <form string="Menu Item">
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                        <field name="chinese_name" placeholder="Chinese Name"/>
                    </div>
                    <group>
                        <group>
                            <field name="price"/>
                            <field name="diet_preference"/>
                            <field name="allergy_ids" widget="many2many_tags"
                                   options="{'color_field': 'color'}"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="school_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="lcs_menu_item_view_search" model="ir.ui.view">
        <field name="name">lcs.menu.item.search</field>
        <field name="model">lcs.menu.item</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="chinese_name"/>
                <field name="diet_preference"/>
                <field name="allergy_ids"/>
                <separator/>
                <filter name="filter_archived" string="Archived"
                        domain="[('active','=',False)]"/>
                <separator/>
                <filter name="groupby_diet" string="Diet"
                        context="{'group_by':'diet_preference'}"/>
                <filter name="groupby_school" string="School"
                        context="{'group_by':'school_id'}"/>
            </search>
        </field>
    </record>

    <record id="lcs_menu_item_action" model="ir.actions.act_window">
        <field name="name">Menu Items</field>
        <field name="res_model">lcs.menu.item</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

</odoo>
