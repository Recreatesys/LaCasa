<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="lcs_school_order_view_list" model="ir.ui.view">
        <field name="name">lcs.school.order.list</field>
        <field name="model">lcs.school.order</field>
        <field name="arch" type="xml">
            <list string="School Orders" default_order="date desc, student_id"
                  decoration-muted="state == 'cancelled'"
                  decoration-success="state == 'submitted'"
                  decoration-info="state == 'draft'"
                  decoration-warning="cutoff_passed and state == 'draft'">
                <field name="date"/>
                <field name="student_id"/>
                <field name="class_company_id"/>
                <field name="school_id"/>
                <field name="menu_item_id"/>
                <field name="price_unit" sum="Total" optional="show"/>
                <field name="cutoff_date" optional="hide"/>
                <field name="cutoff_passed" optional="hide" widget="boolean_toggle"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'submitted'"
                       decoration-muted="state == 'cancelled'"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'invoiced'"/>
            </list>
        </field>
    </record>

    <record id="lcs_school_order_view_form" model="ir.ui.view">
        <field name="name">lcs.school.order.form</field>
        <field name="model">lcs.school.order</field>
        <field name="arch" type="xml">
            <form string="School Order">
                <header>
                    <button name="action_submit" string="Submit"
                            type="object" class="btn-primary"
                            invisible="state != 'draft' or cutoff_passed"/>
                    <button name="action_cancel" string="Cancel"
                            type="object" class="btn-secondary"
                            invisible="state in ('cancelled', 'invoiced') or cutoff_passed"
                            confirm="Cancel this order?"/>
                    <button name="action_reset_to_draft" string="Reset to Draft"
                            type="object" class="btn-link"
                            invisible="state == 'draft' or state == 'invoiced'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,invoiced"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="display_name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="class_company_id"/>
                            <field name="school_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="menu_item_id"/>
                            <field name="price_unit"/>
                            <field name="cutoff_date" readonly="1"/>
                            <field name="cutoff_passed" readonly="1"
                                   widget="boolean_toggle"/>
                            <field name="days_to_cutoff" readonly="1"/>
                            <field name="invoice_line_id" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="lcs_school_order_view_calendar" model="ir.ui.view">
        <field name="name">lcs.school.order.calendar</field>
        <field name="model">lcs.school.order</field>
        <field name="arch" type="xml">
            <calendar string="Orders" date_start="date" mode="month">
                <field name="student_id"/>
                <field name="menu_item_id"/>
                <field name="class_company_id" filters="1"/>
                <field name="state" filters="1"/>
            </calendar>
        </field>
    </record>

    <record id="lcs_school_order_view_search" model="ir.ui.view">
        <field name="name">lcs.school.order.search</field>
        <field name="model">lcs.school.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="student_id"/>
                <field name="menu_item_id"/>
                <field name="class_company_id"/>
                <field name="school_id"/>
                <field name="date"/>
                <separator/>
                <filter name="filter_upcoming" string="Upcoming"
                        domain="[('date', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="filter_submitted" string="Submitted"
                        domain="[('state', '=', 'submitted')]"/>
                <filter name="filter_draft" string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="filter_cancelled" string="Cancelled"
                        domain="[('state', '=', 'cancelled')]"/>
                <filter name="filter_invoiced" string="Invoiced"
                        domain="[('state', '=', 'invoiced')]"/>
                <separator/>
                <filter name="groupby_date" string="Date"
                        context="{'group_by': 'date'}"/>
                <filter name="groupby_class" string="Class"
                        context="{'group_by': 'class_company_id'}"/>
                <filter name="groupby_student" string="Student"
                        context="{'group_by': 'student_id'}"/>
                <filter name="groupby_state" string="Status"
                        context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="lcs_school_order_action" model="ir.actions.act_window">
        <field name="name">School Orders</field>
        <field name="res_model">lcs.school.order</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="search_view_id" ref="lcs_school_order_view_search"/>
    </record>

</odoo>
