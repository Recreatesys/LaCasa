<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_company_form_inherit_school" model="ir.ui.view">
        <field name="name">res.company.form.inherit.school</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='currency_id']" position="after">
                <field name="school_id"/>
                <field name="is_class" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_company_tree_inherit_school" model="ir.ui.view">
        <field name="name">res.company.list.inherit.school</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="school_id"/>
            </xpath>
        </field>
    </record>

</odoo>
