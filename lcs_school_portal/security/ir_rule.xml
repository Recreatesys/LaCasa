<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Portal users can only see / edit orders belonging to their own
             student record (we set partner_id on the portal user to the
             student res.partner). -->
        <record id="rule_lcs_school_order_portal" model="ir.rule">
            <field name="name">School Order: portal user sees only own orders</field>
            <field name="model_id" ref="model_lcs_school_order"/>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="domain_force">[('student_id', '=', user.partner_id.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>
