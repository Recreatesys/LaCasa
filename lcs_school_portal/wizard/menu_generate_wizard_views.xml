<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="lcs_menu_generate_wizard_view_form" model="ir.ui.view">
        <field name="name">lcs.menu.generate.wizard.form</field>
        <field name="model">lcs.menu.generate.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Menu Days">
                <group>
                    <field name="template_id"/>
                    <field name="school_id" readonly="1"/>
                    <field name="class_company_id" readonly="1"/>
                </group>
                <group>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>
                <group>
                    <field name="skip_closed_days"/>
                    <field name="overwrite_existing"/>
                </group>
                <footer>
                    <button name="action_generate" type="object" string="Generate"
                            class="btn-primary"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="lcs_menu_generate_wizard_action" model="ir.actions.act_window">
        <field name="name">Generate from Template</field>
        <field name="res_model">lcs.menu.generate.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
