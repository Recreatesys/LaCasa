<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add Expand Sets button and dish_selected column to SO form -->
    <record id="sale_order_view_form_inherit_lcs_catalog" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.lcs.catalog</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Add Expand Sets button in header -->
            <xpath expr="//field[@name='order_line']" position="before">
                <button name="action_expand_sets"
                        string="Expand Sets"
                        type="object"
                        class="btn-secondary mb-2"
                        icon="fa-cutlery"
                        invisible="state != 'draft'"/>
            </xpath>

            <!-- Add dish_selected checkbox to SO line list -->
            <xpath expr="//field[@name='order_line']//list//field[@name='product_id']" position="before">
                <field name="is_set_line" column_invisible="1"/>
                <field name="dish_selected" string="Pick"
                       readonly="not is_set_line"/>
                <field name="set_product_id" column_invisible="1"/>
                <field name="catering_set_id" column_invisible="1"/>
            </xpath>
        </field>
    </record>

</odoo>
