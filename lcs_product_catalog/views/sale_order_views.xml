<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sale_order_view_form_inherit_lcs_catalog" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.lcs.catalog</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Add a Set / Expand Sets / Reload Sets buttons — placed ABOVE
                 the notebook so they stay visible in both single-day and
                 multi-day layouts (in multi-day the standard Order Lines
                 tab is hidden, replaced by per-day tabs). -->
            <xpath expr="//notebook" position="before">
                <div class="mb-2">
                    <button name="action_open_set_picker"
                            string="Add a Set"
                            type="object"
                            class="btn-primary me-2"
                            icon="fa-plus-circle"/>
                    <button name="action_expand_sets"
                            string="Expand Sets"
                            type="object"
                            class="btn-secondary me-2"
                            icon="fa-cutlery"/>
                    <button name="action_reload_sets"
                            string="Reload Sets (Update Guest Count)"
                            type="object"
                            class="btn-link"
                            icon="fa-refresh"
                            confirm="This will recalculate all set lines based on the current guest count. Your dish selections will be preserved. Continue?"/>
                </div>
            </xpath>

            <!-- Per-day "Add a Set to Slot N" buttons inside each of the 7
                 Day tabs (added by lcs_crm_catering). Each button passes
                 set_picker_day_offset in context so the created line lands
                 on the right day. -->
            <xpath expr="//page[@name='order_lines_day_1']/field[@name='order_line_day_1']" position="before">
                <button name="action_open_set_picker" string="Add a Set to Slot 1"
                        type="object" class="btn-primary mb-2" icon="fa-plus-circle"
                        context="{'set_picker_day_offset': 0}"/>
            </xpath>
            <xpath expr="//page[@name='order_lines_day_2']/field[@name='order_line_day_2']" position="before">
                <button name="action_open_set_picker" string="Add a Set to Slot 2"
                        type="object" class="btn-primary mb-2" icon="fa-plus-circle"
                        context="{'set_picker_day_offset': 1}"/>
            </xpath>
            <xpath expr="//page[@name='order_lines_day_3']/field[@name='order_line_day_3']" position="before">
                <button name="action_open_set_picker" string="Add a Set to Slot 3"
                        type="object" class="btn-primary mb-2" icon="fa-plus-circle"
                        context="{'set_picker_day_offset': 2}"/>
            </xpath>
            <xpath expr="//page[@name='order_lines_day_4']/field[@name='order_line_day_4']" position="before">
                <button name="action_open_set_picker" string="Add a Set to Slot 4"
                        type="object" class="btn-primary mb-2" icon="fa-plus-circle"
                        context="{'set_picker_day_offset': 3}"/>
            </xpath>
            <xpath expr="//page[@name='order_lines_day_5']/field[@name='order_line_day_5']" position="before">
                <button name="action_open_set_picker" string="Add a Set to Slot 5"
                        type="object" class="btn-primary mb-2" icon="fa-plus-circle"
                        context="{'set_picker_day_offset': 4}"/>
            </xpath>
            <xpath expr="//page[@name='order_lines_day_6']/field[@name='order_line_day_6']" position="before">
                <button name="action_open_set_picker" string="Add a Set to Slot 6"
                        type="object" class="btn-primary mb-2" icon="fa-plus-circle"
                        context="{'set_picker_day_offset': 5}"/>
            </xpath>
            <xpath expr="//page[@name='order_lines_day_7']/field[@name='order_line_day_7']" position="before">
                <button name="action_open_set_picker" string="Add a Set to Slot 7"
                        type="object" class="btn-primary mb-2" icon="fa-plus-circle"
                        context="{'set_picker_day_offset': 6}"/>
            </xpath>

            <!-- Add set fields to SO line list -->
            <xpath expr="//field[@name='order_line']//list//field[@name='product_id']" position="before">
                <field name="is_set_line" column_invisible="1"/>
                <field name="is_addon_piece" column_invisible="1"/>
                <field name="dish_selected" string="Pick"
                       readonly="not is_set_line"/>
                <field name="set_line_code" string="Code" readonly="1"
                       optional="show"/>
                <field name="set_product_id" column_invisible="1"/>
                <field name="catering_set_id" column_invisible="1"/>
            </xpath>

            <!-- Add set_unit, full_price, per_piece_price after product_uom_qty -->
            <xpath expr="//field[@name='order_line']//list//field[@name='product_uom_qty']" position="after">
                <field name="set_unit" string="Unit" readonly="1"
                       optional="show"/>
                <field name="full_price" string="Set Price" readonly="1"
                       optional="show"/>
                <field name="per_piece_price" string="Per pc $" readonly="1"
                       optional="hide"/>
            </xpath>

            <!-- Hide Taxes column by default -->
            <xpath expr="//field[@name='order_line']//list//field[@name='tax_ids']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>

            <!-- Hide Discount column by default -->
            <xpath expr="//field[@name='order_line']//list//field[@name='discount']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
        </field>
    </record>

</odoo>
