<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== SET FORM VIEW ==================== -->
    <record id="lcs_catering_set_view_form" model="ir.ui.view">
        <field name="name">lcs.catering.set.form</field>
        <field name="model">lcs.catering.set</field>
        <field name="arch" type="xml">
            <form string="Catering Set">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Mix &amp; Match"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="product_id"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="description"/>
                            <field name="recommendation"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Dishes &amp; Pricing" name="dishes">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="section"/>
                                    <field name="code"/>
                                    <field name="product_id"/>
                                    <field name="size_group"/>
                                    <field name="price_per_piece" string="Per pc"/>
                                    <field name="price_pn_1_1" string="1/1 PN"/>
                                    <field name="price_pn_1_2" string="1/2 PN"/>
                                    <field name="price_s_tray" string="S"/>
                                    <field name="price_m_tray" string="M"/>
                                    <field name="price_l_tray" string="L"/>
                                    <field name="price_xl_tray" string="XL"/>
                                    <field name="eo_qty" string="EO Qty"/>
                                    <field name="eo_unit" string="EO Unit"/>
                                    <field name="remark"/>
                                </list>
                            </field>
                        </page>
                        <page string="Size Rules" name="size_rules">
                            <group string="Auto-size selection based on guest count">
                                <field name="size_rule_ids" nolabel="1">
                                    <list editable="bottom">
                                        <field name="size_group"/>
                                        <field name="min_guests"/>
                                        <field name="max_guests"/>
                                        <field name="size"/>
                                    </list>
                                </field>
                            </group>
                        </page>
                        <page string="Selection Rules" name="rules">
                            <field name="rule_ids">
                                <list editable="bottom">
                                    <field name="category_id"/>
                                    <field name="max_selection"/>
                                    <field name="label"/>
                                </list>
                            </field>
                        </page>
                        <page string="Kitchen Ratio Tiers" name="ratios">
                            <field name="ratio_tier_ids">
                                <list editable="bottom">
                                    <field name="category_id"/>
                                    <field name="min_guests"/>
                                    <field name="max_guests"/>
                                    <field name="kitchen_unit"/>
                                    <field name="ratio"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== SET LIST VIEW ==================== -->
    <record id="lcs_catering_set_view_list" model="ir.ui.view">
        <field name="name">lcs.catering.set.list</field>
        <field name="model">lcs.catering.set</field>
        <field name="arch" type="xml">
            <list string="Catering Sets">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="product_id"/>
                <field name="recommendation"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ==================== ACTION ==================== -->
    <record id="lcs_catering_set_action" model="ir.actions.act_window">
        <field name="name">Catering Sets</field>
        <field name="res_model">lcs.catering.set</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ==================== MENU ==================== -->
    <menuitem id="menu_lcs_catering_set"
              name="Catering Sets"
              parent="sale.sale_menu_root"
              action="lcs_catering_set_action"
              sequence="50"/>

</odoo>
