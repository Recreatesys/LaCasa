<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- ============================================================ -->
    <!-- Private Party — Family Set (Drop-Off Only, 6–8 pax)          -->
    <!-- Set A "Asia Delight":   HK$1,588 base, +HK$198 / extra pax   -->
    <!-- Set B "Western Fever":  HK$1,588 base, +HK$198 / extra pax   -->
    <!-- ============================================================ -->

    <!-- ── Add-on: Extra Guest ── -->
    <record id="addon_fs_extra_guest" model="product.template">
        <field name="name">Family Set Extra Guest
家庭套餐 - 額外人數</field>
        <field name="type">service</field>
        <field name="sale_ok" eval="True"/>
        <field name="purchase_ok" eval="False"/>
        <field name="list_price">198</field>
        <field name="description">per extra person beyond the 6–8 pax base</field>
    </record>

    <!-- ── New Dishes (not in master_dishes.xml) ── -->
    <record id="dish_extra_fs_01" model="product.template">
        <field name="name">Steamed Chicken with Ginger and Scallion, served with Chef's Special Sauce
薑蔥霸王雞配秘製廚師醬汁</field>
        <field name="categ_id" ref="cat_main_dishes"/>
        <field name="type">consu</field>
        <field name="sale_ok" eval="True"/>
        <field name="purchase_ok" eval="False"/>
    </record>

    <!-- ============================================================ -->
    <!-- Family Set A — Asia Delight (HK$1,588 base for 6–8 pax)      -->
    <!-- ============================================================ -->
    <record id="product_fs_set_a" model="product.template">
        <field name="name">Family Set A — Asia Delight (6–8 pax)
家庭套餐 A. 亞洲風味 (6-8人餐)</field>
        <field name="type">service</field>
        <field name="sale_ok" eval="True"/>
        <field name="purchase_ok" eval="False"/>
        <field name="list_price">1588</field>
        <field name="description">Drop-off only — Base for 6–8 pax. Add HK$198 per extra guest beyond 8.</field>
    </record>

    <record id="fs_set_a" model="lcs.catering.set">
        <field name="name">Family Set A — Asia Delight</field>
        <field name="product_id" ref="product_fs_set_a"/>
        <field name="recommendation">Drop-off only · 6–8 pax base @ HK$1,588 · Extra guest HK$198/pax · Steamed chicken portion is fixed (whole, L-tray) regardless of guest count</field>
    </record>

    <record id="fs_set_a_line_01" model="lcs.catering.set.line">
        <field name="set_id" ref="fs_set_a"/>
        <field name="product_id" ref="lcs_product_catalog.dish_004"/>
        <field name="section">Salad — S tray</field>
        <field name="sequence">10</field>
        <field name="size_group">salad_main</field>
    </record>
